{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/components/03-providers.schema.json",
  "title": "Metagraphed OpenAPI components 03-providers",
  "type": "object",
  "components": {
    "schemas": {
      "Provider": {
        "type": "object",
        "required": [
          "schema_version",
          "id",
          "name",
          "kind",
          "website_url",
          "authority"
        ],
        "properties": {
          "schema_version": {
            "const": 1
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "$ref": "#/components/schemas/ProviderKind"
          },
          "website_url": {
            "type": "string",
            "format": "uri"
          },
          "docs_url": {
            "type": "string",
            "format": "uri"
          },
          "github_url": {
            "type": "string",
            "format": "uri"
          },
          "logo_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://example.com/logo.png"],
            "description": "Curated provider logo, else backfilled from the on-chain logo of the single subnet this provider operates. Display-only; never feeds completeness."
          },
          "social": {
            "type": "object",
            "additionalProperties": false,
            "description": "Structured social links: a curated provider override, else borrowed from the single subnet this provider operates. Display-only; never feeds completeness.",
            "properties": {
              "x": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://"
              },
              "telegram": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://"
              },
              "reddit": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://"
              },
              "youtube": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://"
              }
            }
          },
          "team_url": {
            "type": "string",
            "format": "uri"
          },
          "contact_url": {
            "type": "string",
            "format": "uri"
          },
          "authority": {
            "$ref": "#/components/schemas/Authority"
          },
          "public_notes": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "netuids": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "description": "Sorted unique netuids this provider operates a curated surface on (issue #347). Derived/reporting — never feeds completeness."
          },
          "subnet_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of distinct subnets this provider operates (netuids.length)."
          },
          "surface_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of curated surfaces attributed to this provider."
          },
          "endpoint_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of live endpoints attributed to this provider."
          },
          "cluster_id": {
            "type": "string",
            "description": "Shared-team cluster id (registrable domain of team_url/website_url, else the provider id) grouping providers run by the same team (issue #347)."
          }
        },
        "additionalProperties": false
      },
      "ProvidersArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["providers"],
            "properties": {
              "providers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Provider"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "ProviderArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["provider"],
            "properties": {
              "provider": {
                "$ref": "#/components/schemas/Provider"
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "ProviderEndpointsArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["provider", "summary", "endpoints"],
            "properties": {
              "provider": {
                "type": "object",
                "description": "Identity summary of the provider these endpoints belong to.",
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "kind": { "type": "string" },
                  "authority": { "type": "string" }
                },
                "additionalProperties": true
              },
              "summary": {
                "$ref": "#/components/schemas/EndpointSummary"
              },
              "endpoints": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/EndpointResource"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "ProviderReportArtifact": {
        "type": "object",
        "description": "Live cross-subnet performance report for one provider — identity, per-subnet surface-kind breakdown, live probe health, and economics — composed at GET /api/v1/providers/{slug}/report (no static file).",
        "required": [
          "schema_version",
          "source",
          "provider",
          "dimensions",
          "found",
          "subnets",
          "totals"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": { "type": "integer" },
          "source": { "type": "string" },
          "observed_at": { "type": ["string", "null"] },
          "provider": { "type": "string" },
          "dimensions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["identity", "surfaces", "health", "economics"]
            }
          },
          "found": { "type": "boolean" },
          "identity": {
            "type": ["object", "null"],
            "description": "Present only when the identity dimension is requested; null when the provider detail artifact is missing.",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "name": { "type": ["string", "null"] },
              "kind": { "type": ["string", "null"] },
              "website_url": { "type": ["string", "null"] },
              "authority": { "type": ["string", "null"] },
              "subnet_count": { "type": "integer", "minimum": 0 },
              "surface_count": { "type": "integer", "minimum": 0 },
              "endpoint_count": { "type": "integer", "minimum": 0 },
              "netuids": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "subnets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderReportSubnetEntry"
            }
          },
          "totals": { "$ref": "#/components/schemas/ProviderReportTotals" }
        }
      },
      "ProviderReportSubnetEntry": {
        "type": "object",
        "description": "One subnet's slice of a provider report. Optional dimension blocks are present only when requested; each is null when the subnet is unknown to the registry projection.",
        "required": ["netuid", "name", "slug", "found"],
        "additionalProperties": false,
        "properties": {
          "netuid": { "type": "integer", "minimum": 0 },
          "name": { "type": ["string", "null"] },
          "slug": { "type": ["string", "null"] },
          "found": { "type": "boolean" },
          "surfaces": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "count": { "type": "integer", "minimum": 0 },
              "kinds": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/components/schemas/ProviderReportKindCell"
                }
              }
            }
          },
          "health": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "surface_count": { "type": "integer", "minimum": 0 },
              "ok_count": { "type": "integer", "minimum": 0 },
              "avg_latency_ms": { "type": ["number", "null"] }
            }
          },
          "economics": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "registration_cost_tao": { "type": ["number", "null"] },
              "registration_allowed": { "type": "boolean" },
              "open_slots": { "type": ["integer", "null"] },
              "emission_share": { "type": ["number", "null"] },
              "alpha_price_tao": { "type": ["number", "null"] },
              "validator_count": { "type": "integer", "minimum": 0 },
              "miner_count": { "type": "integer", "minimum": 0 },
              "total_stake_tao": { "type": ["number", "null"] },
              "miner_readiness": { "type": ["number", "null"] }
            }
          }
        }
      },
      "ProviderReportKindCell": {
        "type": "object",
        "required": ["count", "ok_count"],
        "additionalProperties": false,
        "properties": {
          "count": { "type": "integer", "minimum": 0 },
          "ok_count": { "type": "integer", "minimum": 0 },
          "avg_latency_ms": { "type": ["number", "null"] }
        }
      },
      "ProviderReportTotals": {
        "type": "object",
        "required": ["subnet_count", "surface_count", "health_ok_ratio"],
        "additionalProperties": false,
        "properties": {
          "subnet_count": { "type": "integer", "minimum": 0 },
          "surface_count": { "type": "integer", "minimum": 0 },
          "health_ok_ratio": { "type": ["number", "null"] }
        }
      }
    }
  }
}
